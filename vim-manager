#!/bin/bash

# ============================================================================
# Vim Manager - A robust, portable Vim configuration manager
# ============================================================================

# Get the script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source all modules
source "$SCRIPT_DIR/vim_manager_modules/config.sh"
source "$SCRIPT_DIR/vim_manager_modules/helpers.sh"
source "$SCRIPT_DIR/vim_manager_modules/core_logic.sh"
source "$SCRIPT_DIR/vim_manager_modules/commands.sh"

# --- Main Execution Logic ---
main() {
    local command="${1:-help}"
    if [ $# -gt 0 ]; then
        shift
    fi

    case "$command" in
        deps)
            do_deps "$@"
            ;;
        install)
            do_install "$@"
            ;;
        bootstrap)
            do_bootstrap "$@"
            ;;
        update)
            do_update "$@"
            ;;
        clean)
            do_clean "$@"
            ;;
        status)
            do_status "$@"
            ;;
        uninstall)
            do_uninstall "$@"
            ;;
        help|*)
            show_help
            ;;
    esac
}

# Run the script
main "$@"
