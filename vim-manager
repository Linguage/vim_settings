        echo "字体状态:"
        if fc-list | grep -i "cascadia" >/dev/null 2>&1; then
            echo "  Cascadia Code: ✓ 已安装"
        else
            echo "  Cascadia Code: ✗ 未安装"
        fi
    fi
}

# 主题管理
manage_themes() {
    local action="$1"
    
    case "$action" in
        "list"|""|"-l")
            list_themes
            ;;
        "install"|"-i")
            install_themes
            ;;
        "switch"|"-s")
            switch_theme_cli
            ;;
        "current"|"-c")
            show_current_theme
            ;;
        *)
            echo "主题管理用法:"
            echo "  $0 themes list          # 列出已安装主题"
            echo "  $0 themes install       # 安装所有主题"
            echo "  $0 themes switch        # 交互式切换主题"
            echo "  $0 themes current       # 显示当前主题"
            ;;
    esac
}

# 列出主题
list_themes() {
    header "🎨 已安装的主题"
    echo ""
    
    local themes_dir="$SCRIPT_DIR/colors"
    if [[ ! -d "$themes_dir" ]]; then
        warning "主题目录不存在"
        return
    fi
    
    local count=0
    for theme_file in "$themes_dir"/*.vim; do
        if [[ -f "$theme_file" ]]; then
            local name=$(basename "$theme_file" .vim)
            local size=$(wc -l < "$theme_file" 2>/dev/null || echo "0")
            printf "  %-15s %s 行\n" "$name" "$size"
            ((count++))
        fi
    done
    
    if [[ $count -eq 0 ]]; then
        warning "未安装任何主题"
        echo ""
        info "运行 '$0 themes install' 来安装主题"
    else
        echo ""
        success "总计: $count 个主题"
    fi
}

# 显示当前主题
show_current_theme() {
    local vimrc_path="$HOME/.vimrc"
    
    if [[ ! -f "$vimrc_path" ]]; then
        warning "配置文件不存在: $vimrc_path"
        return
    fi
    
    local current_theme=$(grep -E '^\s*colorscheme\s+' "$vimrc_path" | head -1 | awk '{print $2}')
    
    if [[ -n "$current_theme" ]]; then
        success "当前主题: $current_theme"
    else
        warning "未设置主题或使用默认主题"
    fi
}

# 命令行主题切换
switch_theme_cli() {
    local themes_dir="$SCRIPT_DIR/colors"
    
    if [[ ! -d "$themes_dir" ]]; then
        error "主题目录不存在，请先运行: $0 themes install"
        return
    fi
    
    local themes=()
    for theme_file in "$themes_dir"/*.vim; do
        if [[ -f "$theme_file" ]]; then
            themes+=($(basename "$theme_file" .vim))
        fi
    done
    
    if [[ ${#themes[@]} -eq 0 ]]; then
        error "未找到任何主题文件"
        return
    fi
    
    header "🎨 主题切换"
    echo ""
    echo "可用主题:"
    for i in "${!themes[@]}"; do
        printf "%2d. %s\n" $((i+1)) "${themes[i]}"
    done
    
    echo ""
    read -p "请选择主题 [1-${#themes[@]}]: " choice
    
    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ $choice -ge 1 ]] && [[ $choice -le ${#themes[@]} ]]; then
        local selected_theme="${themes[$((choice-1))]}"
        set_theme "$selected_theme"
    else
        error "无效选择"
    fi
}

# 设置主题
set_theme() {
    local theme_name="$1"
    local vimrc_path="$HOME/.vimrc"
    local themes_dir="$SCRIPT_DIR/colors"
    
    # 检查主题文件是否存在
    if [[ ! -f "$themes_dir/${theme_name}.vim" ]]; then
        error "主题文件不存在: ${theme_name}.vim"
        return
    fi
    
    if [[ ! -f "$vimrc_path" ]]; then
        error "配置文件不存在: $vimrc_path"
        return
    fi
    
    # 备份配置文件
    cp "$vimrc_path" "${vimrc_path}.backup.$(date +%Y%m%d_%H%M%S)"
    
    # 更新主题设置
    if grep -q "^colorscheme" "$vimrc_path"; then
        # 替换现有的主题设置
        sed -i.bak "s/^colorscheme.*/colorscheme $theme_name/" "$vimrc_path"
        rm -f "${vimrc_path}.bak"
    else
        # 添加主题设置
        echo "colorscheme $theme_name" >> "$vimrc_path"
    fi
    
    success "已切换到主题: $theme_name"
    info "重新启动 Vim 生效，或在 Vim 中运行 ':colorscheme $theme_name'"
}

# 主函数
main() {
    case "${1:-help}" in
        "install"|"i")
            install_environment
            ;;
        "update"|"u")
            update_plugins
            ;;
        "plugins"|"p")
            shift
            manage_plugins "$@"
            ;;
        "config"|"c")
            case "$2" in
                "link") link_config ;;
                *) link_config ;;
            esac
            ;;
        "start"|"s")
            shift
            start_macvim "$@"
            ;;
        "status"|"st")
            check_status
            ;;
        "themes"|"t")
            shift
            manage_themes "$@"
            ;;
        "help"|"h"|"-h"|"--help")
            show_help
            ;;
        "version"|"v"|"-v"|"--version")
            echo "Vim Manager v$VERSION (Updated: $UPDATED)"
            ;;
        *)
            error "未知命令: $1"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# 运行主函数
main "$@"
