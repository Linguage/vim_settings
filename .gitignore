# =================
# Keep Essential Files
# =================

# Explicitly keep essential vim configuration files
!vimrc
!switch_theme.vim
!vim-manager
!clean_empty_files.sh
!README.md
!colors/
!colors/*.vim
!plugins/
!docs/
!docs/*.md

# Keep plugin directories but ignore some generated files within them
plugins/**/.git/
plugins/**/*.pyc
plugins/**/.DS_Store
plugins/**/tags
plugins/**/
